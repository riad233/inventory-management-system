# Development Dockerfile with debugging and development tools
FROM php:8.2-apache

# Install development dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libzip-dev \
    zip \
    unzip \
    curl \
    git \
    vim \
    mariadb-client \
    postgresql-client \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions
RUN docker-php-ext-install -j$(nproc) \
    mysqli \
    pdo \
    pdo_mysql \
    zip \
    && docker-php-ext-enable mysqli pdo pdo_mysql zip

# Install Xdebug for debugging
RUN pecl install xdebug && docker-php-ext-enable xdebug

# Copy Xdebug configuration
COPY docker/xdebug.ini /usr/local/etc/php/conf.d/xdebug.ini

# Install Composer
COPY --from=composer:2.6 /usr/bin/composer /usr/bin/composer

# Copy development PHP configuration
COPY docker/php-dev.ini /usr/local/etc/php/conf.d/php-dev.ini

# Copy Apache configuration
COPY docker/apache.conf /etc/apache2/apache2.conf
COPY docker/vhost.conf /etc/apache2/sites-available/000-default.conf

# Enable Apache modules
RUN a2enmod rewrite headers expires

# Set working directory
WORKDIR /var/www/html

# Copy application code
COPY . /var/www/html

# Install dependencies
RUN if [ -f "composer.json" ]; then composer install; else composer init --no-interaction; fi

# Create necessary directories
RUN mkdir -p storage/logs storage/cache public/uploads && \
    chown -R www-data:www-data /var/www/html && \
    chmod -R 775 storage public/uploads

# Set environment
ENV APACHE_RUN_USER=www-data \
    APACHE_RUN_GROUP=www-data \
    PHP_IDE_CONFIG="serverName=localhost" \
    XDEBUG_MODE=debug \
    XDEBUG_CONFIG="client_host=host.docker.internal client_port=9003"

EXPOSE 80

# Start Apache in foreground
CMD ["apache2-foreground"]
