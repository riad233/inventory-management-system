# .dockerignore file
# Excludes files from Docker build context

# Git
.git
.gitignore
.gitattributes

# Documentation
*.md
docs/
README*
CHANGELOG*
LICENSE*

# Environment files
.env
.env.local
.env.*.local
.env.example

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.editorconfig

# Testing and Development
tests/
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache
coverage/
.coverage
.pytest_cache
jest.config.js

# Build files
node_modules/
dist/
build/
vendor/composer
vendor/bin

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
.circleci/

# Docker
docker-compose*.yml
docker/
Dockerfile*
.dockerignore

# Database
database/migrations/*.php
!database/migrations/Migration.php
!database/migrations/Migrator.php

# Logs and temporary files
storage/logs/
storage/cache/
storage/test-*
*.log

# Kubernetes and Infrastructure
kubernetes/
terraform/
haproxy.cfg
nginx.conf

# OS files
Thumbs.db
*.class
*.o
*.a
*.so

# Package manager locks (unless pinned)
package-lock.json.bak
composer.lock.bak
