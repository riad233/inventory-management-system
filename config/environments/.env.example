# Application Environment Configuration Template
# Copy this file to .env and update with your environment-specific values

# ========================================
# Application Settings
# ========================================
APP_ENV=production
APP_DEBUG=false
APP_NAME=IMS
APP_URL=https://ims.example.com
APP_TIMEZONE=UTC

# ========================================
# Database Configuration
# ========================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=ims_db
DB_USER=ims_user
DB_PASSWORD=secure_database_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Database Connection Pool
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# Database Replication (optional)
DB_READ_HOST=db-read-replica
DB_READ_PORT=3306
DB_READ_USER=ims_user
DB_READ_PASSWORD=secure_database_password

# ========================================
# Cache Configuration
# ========================================
CACHE_DRIVER=redis
CACHE_TTL=3600

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DATABASE=0
REDIS_TIMEOUT=30
REDIS_RETRY_INTERVAL=100
REDIS_READ_TIMEOUT=null

# File Cache (fallback)
FILE_CACHE_PATH=/var/www/html/storage/cache

# ========================================
# Session Configuration
# ========================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ========================================
# Queue & Jobs Configuration
# ========================================
QUEUE_DRIVER=sync
QUEUE_HOST=localhost
QUEUE_PORT=6379
QUEUE_PASSWORD=
QUEUE_DATABASE=0

# ========================================
# Mail Configuration
# ========================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ims.example.com
MAIL_FROM_NAME="IMS System"

# ========================================
# Security Configuration
# ========================================
APP_KEY=base64:your_application_key_here_32_chars
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# CORS Settings
CORS_ALLOWED_ORIGINS=https://ims.example.com,https://api.ims.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-CSRF-TOKEN,X-Requested-With
CORS_EXPOSE_HEADERS=Authorization,Content-Length,X-JSON-Response-Length
CORS_MAX_AGE=86400
CORS_SUPPORTS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ========================================
# Logging Configuration
# ========================================
LOG_DRIVER=stack
LOG_LEVEL=error
LOG_PATH=/var/www/html/storage/logs

# ========================================
# Security Headers
# ========================================
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

# ========================================
# File Upload Configuration
# ========================================
UPLOAD_MAX_FILESIZE=50M
UPLOAD_PATH=/var/www/html/public/uploads
UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif
UPLOAD_SCAN_ANTIVIRUS=false
ANTIVIRUS_API_KEY=

# ========================================
# Performance Monitoring
# ========================================
PERFORMANCE_MONITORING_ENABLED=true
SLOW_QUERY_THRESHOLD=1000
SLOW_REQUEST_THRESHOLD=1000

# ========================================
# Third-party Services
# ========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=ims-uploads
AWS_URL=https://s3.amazonaws.com

# Slack Integration
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# ========================================
# Feature Flags
# ========================================
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_API_RATE_LIMITING=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_AUDIT_LOGGING=true

# ========================================
# Development/Testing (NEVER in production)
# ========================================
# XDEBUG_ENABLED=false
# TEST_DATABASE_NAME=ims_test
# TEST_DATABASE_USER=test_user
# TEST_DATABASE_PASSWORD=test_password
