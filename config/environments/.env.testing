# Testing Environment Configuration

APP_ENV=testing
APP_DEBUG=true
APP_NAME=IMS
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

# Database - Test database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ims_test
DB_USER=ims_user
DB_PASSWORD=test_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_POOL_MIN=1
DB_POOL_MAX=2

# Cache - File cache for testing
CACHE_DRIVER=file
CACHE_TTL=0
FILE_CACHE_PATH=./storage/test-cache

# Session - File session for testing
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIES=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Queue - Synchronous in testing
QUEUE_DRIVER=sync

# Mail - Mailhog for testing
MAIL_DRIVER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=test@ims.local
MAIL_FROM_NAME="IMS Test"

# Security - Test keys
APP_KEY=base64:test_key_32_characters_long_here
JWT_SECRET=test_jwt_secret_here
ENCRYPTION_KEY=test_encryption_key_here

# CORS - Test configuration
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_EXPOSE_HEADERS=*
CORS_MAX_AGE=0
CORS_SUPPORTS_CREDENTIALS=true

# Rate Limiting - Disabled in testing
RATE_LIMIT_ENABLED=false

# Logging - Error level only in testing
LOG_DRIVER=stack
LOG_LEVEL=error
LOG_PATH=./storage/logs/test

# File Upload - Temporary uploads
UPLOAD_MAX_FILESIZE=50M
UPLOAD_PATH=./storage/test-uploads
UPLOAD_ALLOWED_EXTENSIONS=*
UPLOAD_SCAN_ANTIVIRUS=false

# Performance - Minimal monitoring in testing
PERFORMANCE_MONITORING_ENABLED=false
SLOW_QUERY_THRESHOLD=0
SLOW_REQUEST_THRESHOLD=0

# Feature Flags - All enabled for testing
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_API_RATE_LIMITING=false
FEATURE_ADVANCED_REPORTING=true
FEATURE_AUDIT_LOGGING=true
